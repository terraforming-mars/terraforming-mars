{
  "name": "terraforming-mars",
  "version": "1.0.0",
  "description": "Terraforming Mars Game",
  "engines": {
    "node": "22.x"
  },
  "private": true,
  "dependencies": {
    "ansi-escape-sequences": "^6.2.2",
    "chart.js": "^4.4.7",
    "console-stamp": "3.1.2",
    "cross-env": "^10.1.0",
    "dialog-polyfill": "^0.5.1",
    "dotenv": "^17.3.1",
    "html-escaper": "^3.0.3",
    "markdown-it": "^14.1.1",
    "mnemonist": "^0.40.4",
    "prom-client": "^15.1.3",
    "uuid": "^14.0.0",
    "vue": "^3.4.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@stylistic/stylelint-plugin": "^5.1.0",
    "@types/ansi-escape-sequences": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/html-escaper": "^3.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^7.14.7",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vue/test-utils": "^2.0.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "compression-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "less": "^4.6.4",
    "less-loader": "^12.3.2",
    "mocha": "^11.7.5",
    "mochapack": "^2.1.5",
    "postcss-html": "^1.8.1",
    "rimraf": "^6.1.3",
    "spectre.css": "^0.5.8",
    "style-loader": "^4.0.0",
    "stylelint": "^17.12.0",
    "stylelint-config-recommended-less": "^4.2.1",
    "ts-loader": "^9.5.7",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vue-loader": "^17.0.0",
    "vue-tsc": "^3.2.9",
    "zlib": "^1.0.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0",
    "pg": "^8.19.0"
  },
  "scripts": {
    "start": "node build/src/server/server.js",
    "start:prof": "node --prof build/src/server/server.js",
    "build": "npm run make:static && npm run build:server && npm run build:client",
    "build:client": "npm run make:cards && cross-env NODE_ENV=production webpack",
    "build:server": "tsc --build src/tsconfig.json && tsc-alias -p src/tsconfig.json",
    "build:test": "tsc --build tests/tsconfig.json",
    "build:tests": "tsc --build tests/tsconfig.json",
    "clean": "rimraf ./build/ ./src/genfiles/",
    "lint": "npm run lint:server && npm run lint:i18n && npm run lint:client && npm run lint:css",
    "lint:client": "vue-tsc --noEmit -p tsconfig.vue-tsc.json",
    "lint:server": "eslint --cache src tests",
    "lint:i18n": "npx tsx src/tools/translation_audit.ts",
    "lint:css": "stylelint \"src/styles/**/*.less\" \"src/client/**/*.vue\"",
    "lint:css:fix": "stylelint --fix \"src/styles/**/*.less\" \"src/client/**/*.vue\"",
    "lint:fix": "eslint --fix src tests",
    "make:cards": "npx tsx src/server/tools/export_card_rendering.ts",
    "make:css": "lessc src/styles/common.less build/styles.css && node src/server/tools/gzip.js",
    "watch:less": "npx tsx scripts/watchcss.ts src/styles",
    "make:json": "npx tsx src/tools/make_static_json.ts",
    "make:static": "npm run make:css && npm run make:json",
    "test": "npm run test:server && npm run test:client",
    "test:server": "mocha --import=tsx --require tests/testing/setup.ts \"tests/*.spec.ts\" \"tests/!(client|integration)/**/*.spec.ts\"",
    "test:integration": "mocha --import=tsx --no-timeouts \"tests/integration/**/*.spec.ts\"",
    "test:postgresql": "mocha --import=tsx \"tests/integration/PostgreSQL.spec.ts\"",
    "test:client": "cross-env NODE_ENV=development mochapack --require tests/client/components/setup.ts \"tests/client/**/*.spec.ts\"",
    "test:client:watch": "cross-env NODE_ENV=development mochapack --watch --require tests/client/components/setup.ts \"tests/client/**/*.spec.ts\"",
    "dev:client": "cross-env NODE_ENV=development webpack --watch",
    "dev:server": "cross-env NODE_ENV=development tsx watch src/server/server.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/terraforming-mars/terraforming-mars.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/terraforming-mars/terraforming-mars/issues"
  },
  "homepage": "https://github.com/terraforming-mars/terraforming-mars#readme"
}
