{
  "name": "terraforming-mars",
  "version": "1.0.0",
  "description": "Terraforming Mars Game",
  "engines": {
    "node": ">=22.x <=24.x"
  },
  "private": true,
  "dependencies": {
    "ansi-escape-sequences": "^6.2.2",
    "chart.js": "^4.4.7",
    "console-stamp": "3.1.2",
    "cross-env": "^7.0.3",
    "dialog-polyfill": "^0.5.1",
    "dotenv": "^17.3.1",
    "html-escaper": "^3.0.3",
    "mnemonist": "^0.40.3",
    "prom-client": "^15.1.3",
    "uuid": "^11.0.5",
    "vue": "^3.4.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/ansi-escape-sequences": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chai": "^4.3.1",
    "@types/chai-as-promised": "^8.0.2",
    "@types/html-escaper": "^3.0.0",
    "@types/mocha": "^9.1.1",
    "@types/node": "^10.17.47",
    "@types/pg": "^7.14.7",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vue/test-utils": "^2.0.0",
    "chai": "^4.2.0",
    "chai-as-promised": "^8.0.2",
    "chai-deep-equal-ignore-undefined": "^1.1.1",
    "compression-webpack-plugin": "^8.0.0",
    "css-loader": "^5.2.6",
    "eslint": "^10.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^16.0.0",
    "jsdom": "^22.1.0",
    "less": "^4.6.4",
    "less-loader": "^10.0.0",
    "mocha": "^9.2.2",
    "mochapack": "^2.1.5",
    "rimraf": "^3.0.2",
    "spectre.css": "^0.5.8",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "ts-mocha": "^9.0.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-webpack-plugin": "^3.5.1",
    "typescript": "^5.5.0",
    "vue-loader": "^17.0.0",
    "vue-tsc": "^2.0.0",
    "zlib": "^1.0.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.8.0",
    "pg": "^8.2.1"
  },
  "scripts": {
    "start": "node build/src/server/server.js",
    "start:prof": "node --prof build/src/server/server.js",
    "build": "npm run make:static && npm run build:server && npm run build:client",
    "build:client": "npm run make:cards && cross-env NODE_ENV=production webpack",
    "build:server": "tsc --build src/tsconfig.json",
    "build:test": "tsc --build tests/tsconfig.json",
    "build:tests": "tsc --build tests/tsconfig.json",
    "clean": "rimraf ./build/ ./src/genfiles/",
    "lint": "npm run lint:server && npm run lint:i18n && npm run lint:client",
    "lint:client": "vue-tsc --noEmit -p tsconfig.vue-tsc.json",
    "lint:server": "eslint --cache src tests",
    "lint:i18n": "npx ts-node src/tools/translation_audit.ts",
    "lint:fix": "eslint --fix src tests",
    "make:cards": "node build/src/server/tools/export_card_rendering.js",
    "make:css": "lessc src/styles/common.less build/styles.css && node src/server/tools/gzip.js",
    "watch:css": "node scripts/watchcss.js src/styles",
    "make:json": "npx ts-node src/tools/make_static_json.ts",
    "make:static": "npm run make:css && npm run make:json",
    "test": "npm run test:server && npm run test:client",
    "test:server": "ts-mocha --experimental-transform-types -p tests/tsconfig.json -r tests/testing/setup.ts \"tests/*.spec.ts\" \"tests/!(client|integration)/**/*.spec.ts\"",
    "test:integration": "ts-mocha --no-timeouts -p tests/tsconfig.json \"tests/integration/**/*.spec.ts\"",
    "test:postgresql": "ts-mocha -p tests/tsconfig.json \"tests/integration/PostgreSQL.spec.ts\"",
    "test:client": "cross-env NODE_ENV=development mochapack --require tests/client/components/setup.ts \"tests/client/**/*.spec.ts\"",
    "test:client:watch": "cross-env NODE_ENV=development mochapack --watch --require tests/client/components/setup.ts \"tests/client/**/*.spec.ts\"",
    "dev:client": "cross-env NODE_ENV=development webpack --watch",
    "dev:server": "cross-env NODE_ENV=development tsnd src/server/server.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/terraforming-mars/terraforming-mars.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/terraforming-mars/terraforming-mars/issues"
  },
  "homepage": "https://github.com/terraforming-mars/terraforming-mars#readme"
}
